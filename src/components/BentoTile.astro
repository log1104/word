---
interface Props {
	post: {
		id: string;
		data: {
			title: string;
			description: string;
			pubDate: Date;
			category: string;
		};
	};
	index?: number;
}

const { post, index = 0 } = Astro.props;

// Liturgical palette mapped to CSS variable tokens defined in global.css
type CategoryKey = 'study' | 'news' | 'reflection' | 'default';

const categoryTokens: Record<CategoryKey, { bg: string; accent: string; glow: string }> = {
	study:      { bg: 'var(--bento-study-bg)',      accent: 'var(--bento-study-accent)',      glow: 'var(--bento-study-glow)' },
	news:       { bg: 'var(--bento-news-bg)',        accent: 'var(--bento-news-accent)',        glow: 'var(--bento-news-glow)' },
	reflection: { bg: 'var(--bento-reflection-bg)', accent: 'var(--bento-reflection-accent)', glow: 'var(--bento-reflection-glow)' },
	default:    { bg: 'var(--bento-default-bg)',     accent: 'var(--bento-default-accent)',     glow: 'var(--bento-default-glow)' },
};

const paletteCycle: CategoryKey[] = ['study', 'news', 'reflection', 'default'];
const currentThemeKey = paletteCycle[index % paletteCycle.length];
const tokens = categoryTokens[currentThemeKey];

// Inline CSS vars for the card — drives all colour without Tailwind class proliferation
const cardStyle = [
	`--accent: ${tokens.accent}`,
	`--accent-glow: ${tokens.glow}`,
	// Radial depth: accent colour blooms subtly from bottom-right corner
	`background: radial-gradient(ellipse at 95% 105%, ${tokens.glow} 0%, transparent 55%), ${tokens.bg}`,
].join('; ');
---

<article
	class="bento-card group relative rounded-[--radius-bento] border min-h-[260px] flex flex-col p-6 transition-all duration-300 bento-article"
	style={cardStyle}
>
	<a href={`/blog/${post.id}/`} class="relative z-10 flex flex-col h-full w-full">

		<!-- Z-Pattern Row 1: Icon ghost-button + Category label + Date -->
		<div class="flex items-center gap-3 mb-5">
			<!-- Ghost icon badge -->
			<div
				class="w-7 h-7 flex items-center justify-center rounded text-xs font-bold uppercase flex-shrink-0"
				style="border: 1px solid var(--accent); color: var(--accent);"
			>
				{post.data.category.charAt(0)}
			</div>
			<span class="text-xs font-semibold tracking-widest uppercase" style="color: var(--accent); opacity: 0.8;">
				{post.data.category}
			</span>
			<time
				datetime={post.data.pubDate.toISOString()}
				class="ml-auto text-xs text-slate-500 dark:text-slate-500 tabular-nums"
			>
				{post.data.pubDate.toLocaleDateString('en-GB')}
			</time>
		</div>

		<!-- Z-Pattern Row 2: Title (high contrast hook) -->
		<h2 class="font-heading font-bold text-xl leading-snug text-gray-100 mb-3">
			{post.data.title}
		</h2>

		<!-- Z-Pattern Row 3: Excerpt (dimmed) -->
		{post.data.description && (
			<p class="text-sm leading-relaxed line-clamp-3 text-slate-400">
				{post.data.description}
			</p>
		)}

		<!-- Z-Pattern Row 4: Arrow CTA — bottom-right, hover reveal -->
		<div class="mt-auto pt-5 flex justify-end">
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="20"
				height="20"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="transition-all duration-300 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0"
				style="color: var(--accent);"
				aria-label="Read post"
			>
				<line x1="7" y1="17" x2="17" y2="7"/>
				<polyline points="7 7 17 7 17 17"/>
			</svg>
		</div>

	</a>
</article>

<style>
	.bento-article {
		border-color: color-mix(in srgb, var(--accent) 20%, transparent);
		transition: border-color 0.3s ease;
	}
	.bento-article:hover {
		border-color: color-mix(in srgb, var(--accent) 55%, transparent);
	}
</style>
