---
interface Props {
	categories: string[];
}

const { categories } = Astro.props;
---

<div class="flex flex-wrap gap-2">
	{categories.map((category) => (
		<a
			href={`/categories/${category}`}
			class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-accent/10 text-accent hover:bg-accent/20 transition-colors"
		>
			{category}
		</a>
	))}
</div>
