---
interface Props {
	post: {
		id: string;
		data: {
			title: string;
			description: string;
			pubDate: Date;
			heroImage?: string;
			tags: string[];
			category: string;
		};
	};
}

const { post } = Astro.props;
---

<article class="group rounded-lg border border-gray-200 dark:border-gray-800 overflow-hidden hover:shadow-lg transition-shadow">
	<a href={`/blog/${post.id}/`} class="block">
		{post.data.heroImage && (
			<img src={post.data.heroImage} alt={post.data.title} class="w-full h-48 object-cover" />
		)}
		<div class="p-6">
			<div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
				<span class="text-primary hover:underline">{post.data.category}</span>
				<span>&middot;</span>
				<time datetime={post.data.pubDate.toISOString()}>
					{post.data.pubDate.toLocaleDateString('en-GB')}
				</time>
			</div>
			<h2 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">
				{post.data.title}
			</h2>
			<p class="text-gray-600 dark:text-gray-400 line-clamp-2">{post.data.description}</p>
		</div>
	</a>
</article>
