---
interface Props {
	tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2 mt-3">
	{tags.map((tag) => {
		const slug = tag.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
		return (
			<a
				href={`/tags/${slug}`}
				class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-primary/10 text-primary hover:bg-primary/20 transition-colors"
			>
				#{tag}
			</a>
		);
	})}
</div>
