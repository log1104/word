---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagMap = new Map<string, number>();

for (const post of posts) {
	for (const tag of post.data.tags) {
		tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
	}
}

const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags | Word" description="Browse posts by tag">
	<section>
		<h1 class="text-4xl font-bold mb-8">Tags</h1>
		{tags.length > 0 ? (
			<div class="flex flex-wrap gap-3">
				{tags.map(([tag, count]) => (
					<a
						href={`/tags/${tag}`}
						class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-primary/10 text-primary hover:bg-primary/20 transition-colors font-medium"
					>
						#{tag}
						<span class="text-xs opacity-75">({count})</span>
					</a>
				))}
			</div>
		) : (
			<p class="text-gray-500 dark:text-gray-400">No tags yet.</p>
		)}
	</section>
</BaseLayout>
