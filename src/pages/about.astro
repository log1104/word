---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_VERSION } from '../consts';
---

<BaseLayout title="About | Word" description="About this blog">
	<section>
		<h1 class="text-4xl font-bold mb-6">About</h1>
		<div class="prose prose-lg dark:prose-invert max-w-none">
			<p>
				Welcome to <strong>Word</strong> — a blog powered by Astro and Sveltia CMS,
				hosted on Cloudflare Pages.
			</p>
			<p>
				This is a static blog built for speed and simplicity. Content is managed
				through a browser-based CMS and deployed automatically.
			</p>

			<hr class="mt-12 mb-6 border-gray-200 dark:border-gray-800" />
			
			<div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
				<span>Version {SITE_VERSION}</span>
			</div>
		</div>
	</section>
</BaseLayout>
