---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
	pubDate?: Date;
}

const { title, description, image, pubDate } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
	<SEO title={title} description={description} image={image} pubDate={pubDate} />
</head>
<body class="min-h-screen flex flex-col bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
	<Header />
	<main class="flex-1 max-w-4xl mx-auto w-full px-4 py-8">
		<slot />
	</main>
	<Footer />
</body>
</html>
